# Log level: INFO (default) or DEBUG (verbose command output, timing, stdout/stderr)
LOG_LEVEL=INFO

# Stream subprocess stdout/stderr to terminal in real-time (e.g. ffmpeg progress)
# Set to true to see colored ffmpeg output live; independent of LOG_LEVEL
STREAM_CMD_OUTPUT=false

S3_ENDPOINT=http://192.168.1.188:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_REGION=us-east-1
S3_BUCKET=fevid
S3_BUCKET_ORIGIN=fevid-orig

PIPELINE_API_URL=https://local.test
PIPELINE_API_VERIFY_SSL=false
POLL_INTERVAL=30
PIPELINE_WORK_DIR=/tmp/pipeline-work

VIDEO_CODEC=libx264
VIDEO_CODEC_TAG=avc1
VIDEO_CODEC_PARAMS=keyint=60:min-keyint=60:scenecut=0
VIDEO_PRESET=slow
# crf=18
VIDEO_CRF=18
VIDEO_PIX_FMT=yuv420p

# Rate control (maxrate + bufsize). Set false to disable entirely.
# Override values are in kbps; leave empty to use per-profile hardcoded values.
RATE_CONTROL_ENABLED=true
RATE_CONTROL_MAXRATE=
RATE_CONTROL_BUFSIZE=

# 4
HLS_SEGMENT_DURATION=3
HLS_SEGMENT_TYPE=fmp4
HLS_PLAYLIST_TYPE=vod
HLS_KEYFRAME_INTERVAL=60

PREVIEW_DURATION=20

WEBP_QUALITY=100
WEBP_LOSSLESS=false
WEBP_MAX_DIMENSION=0

# Blur parameters for paywalled gallery images
BLUR_SIGMA=20
BLUR_STEPS=3

# Watermark (drawtext) toggle — set to true to enable watermarking
WATERMARK_ENABLED=false
WATERMARK_TEXT=fevid.cloud/
WATERMARK_FONT=
WATERMARK_COLOR=#7ccf00
WATERMARK_X=5
WATERMARK_Y=5
WATERMARK_BORDERCOLOR=black
WATERMARK_BORDERW=1
# Watermark size = sqrt(w²+h²) * font_ratio  (diagonal-based, responsive across resolutions)
WATERMARK_FONT_RATIO=0.02
