S3_ENDPOINT=http://192.168.1.188:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_REGION=us-east-1
S3_BUCKET=fevid
S3_BUCKET_ORIGIN=fevid-orig

PIPELINE_API_URL=https://local.test
PIPELINE_API_VERIFY_SSL=false
POLL_INTERVAL=30
PIPELINE_WORK_DIR=/tmp/pipeline-work

VIDEO_CODEC=libx264
VIDEO_CODEC_TAG=avc1
VIDEO_CODEC_PARAMS=keyint=60:min-keyint=60:scenecut=0
VIDEO_PRESET=slow
# 23 # 18
VIDEO_CRF=20
VIDEO_CAP_SCALE=0.9
VIDEO_BUF_FACTOR=2
VIDEO_PIX_FMT=yuv420p

# 4
HLS_SEGMENT_DURATION=3
HLS_SEGMENT_TYPE=fmp4
HLS_PLAYLIST_TYPE=vod
HLS_KEYFRAME_INTERVAL=60

PREVIEW_DURATION=20

WEBP_QUALITY=100
WEBP_LOSSLESS=false
WEBP_MAX_DIMENSION=0

# Watermark (drawtext) toggle — set to true to enable watermarking
WATERMARK_ENABLED=false
WATERMARK_TEXT=fevid.cloud/
WATERMARK_FONT=
WATERMARK_FONT_SIZE=h*0.02
WATERMARK_COLOR=#7ccf00
WATERMARK_X=5
WATERMARK_Y=5
WATERMARK_BOX=false
WATERMARK_BOXCOLOR=black@0.5
WATERMARK_BOXBORDERW=6
WATERMARK_BORDERCOLOR=black
WATERMARK_BORDERW=1
